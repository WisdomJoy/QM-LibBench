            "./opencv_perf_imgproc --gtest_filter=Size_MatType_BorderType_blur16x16.*",
            "./opencv_perf_imgproc --gtest_filter=Size_MatType_BorderType_blur5x5.*",
            "./opencv_perf_imgproc --gtest_filter=Size_MatType_BorderType_ksize_box.*",
            "./opencv_perf_imgproc --gtest_filter=Size_ksize_BorderType_box_CV8U_CV16U.*",
            "./opencv_perf_imgproc --gtest_filter=Size_MatType_BorderType_ksize_box_inplace.*",
            "./opencv_perf_imgproc --gtest_filter=Size_MatType_stackblur3x3.*",
            "./opencv_perf_imgproc --gtest_filter=Size_MatType_stackblur101x101.*"
